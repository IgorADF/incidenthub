{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,

  "agent": {
    "caveman-investigator": {
      "mode": "primary",
      "model": "zai/glm-5.2",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
      },
    },
    "caveman-reviewer": {
      "mode": "primary",
      "model": "zai/glm-5.2",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
      },
    },
  },

  "mcp": {
    // Backend services
    "bullmq": {
      "type": "remote",
      "url": "https://docs.bullmq.io/~gitbook/mcp",
      "enabled": true,
    },

    // UI
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true,
    },

    // All
    "zod": {
      "type": "remote",
      "url": "https://mcp.inkeep.com/zod/mcp",
      "enabled": true,
    },
  },

  // "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
}
