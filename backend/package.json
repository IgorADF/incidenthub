{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build": "tsc",
    "start:api": "node ./dist/apps/api/server.js",
    "start:worker:healthcheck": "node ./dist/apps/workers/healthcheck/main.js",
    "start:worker:notification": "node ./dist/apps/workers/notification/main.js",
    "dev:api": "tsx ./src/apps/api/server.ts",
    "dev:worker:healthcheck": "tsx ./src/apps/workers/healthcheck/main.ts",
    "dev:worker:notification": "tsx ./src/apps/workers/notification/main.ts",
    "tests": "npx vitest --config ./vitest.config.ts",
    "tests:e2e": "vitest run --config ./vitest.e2e.config.ts",
    "type:check": "npx tsc --noEmit",
    "prisma:generate": "npx prisma generate --sql",
    "db:generate": "npx prisma generate --sql",
    "db:migrate:dev": "npm run db:generate && npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "lint": "npx @biomejs/biome lint --max-diagnostics 100",
    "format": "npx @biomejs/biome format --write ./src",
    "organize:all": "npx @biomejs/biome check --write ./src"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bcrypt": "6.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "8.0.1",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "6.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "1.18.0",
    "bcrypt": "6.0.0",
    "bullmq": "5.78.1",
    "dotenv": "^17.4.2",
    "fastify": "5.8.5",
    "fastify-type-provider-zod": "6.1.0",
    "ioredis": "5.11.1",
    "jsonwebtoken": "9.0.3",
    "node-cron": "4.5.0",
    "nodemailer": "9.0.1",
    "pg": "^8.21.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "uuidv7": "1.2.1",
    "zod": "4.4.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "bullmq": {
      "ioredis": "5.11.1"
    }
  }
}
